
!RKS B3LYP def2-TZVPP TightSCF Opt D3BJ # 6-31G(d,p)
 
%pal nprocs 2 end
%maxcore 3000

%cpcm
  smd true
  SMDsolvent "WATER"
  end

%scf
  MaxIter 1000
  SOSCF Start 0.00033
  end
end

%output
  PrintLevel Normal
  Print[ P_OrbEn ] 2        # print ALL orbital energies (not just up to LUMO+9) :contentReference[oaicite:10]{index=10}
  XYZFile true              # writes basename.xyz (handy for reuse) :contentReference[oaicite:11]{index=11}
  end

